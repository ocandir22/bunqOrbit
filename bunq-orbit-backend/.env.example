# bunq API Configuration
BUNQ_ENV=sandbox
BUNQ_BASE_URL=https://public-api.sandbox.bunq.com/v1
BUNQ_API_KEY=your_sandbox_api_key_here
BUNQ_COMPANY_NAME="Your Name"
BUNQ_LOGIN_CODE=
BUNQ_DEVICE_DESCRIPTION=bunq_orbit_company_dev
BUNQ_PRIVATE_KEY_PATH=./installation.key
BUNQ_PUBLIC_KEY_PATH=./installation.pub

# AWS / Amazon Bedrock Configuration
VISION_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN="IQoJb3JpZ2luX2VjEL///////////wEaCX
# AWS_SESSION_TOKEN=your_session_token_if_using_temporary_credentials

# App Configuration
PORT=3000
MAX_FILE_MB=10
UPLOAD_DIR=uploads


